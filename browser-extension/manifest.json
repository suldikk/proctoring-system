{
  "manifest_version": 3,
  "name": "Java Proctoring Guard",
  "version": "0.1.0",
  "description": "Минимальное расширение для подтверждения активного прокторинга на странице экзамена.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:8081/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/exam-demo/*",
        "http://localhost:8081/exam-demo/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Java Proctoring Guard",
    "default_popup": "popup.html"
  }
}
